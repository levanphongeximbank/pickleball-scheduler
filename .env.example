# Pickleball Scheduler Pro v4.0

# Đặt trong .env.local (ưu tiên hơn .env.development). Hỗ trợ eyJ... hoặc sb_publishable_...
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# RBAC: local dev mặc định false. Production/RC: true (xem .env.production.example)
VITE_RBAC_ENABLED=false

# Payment: dev = nâng cấp gói ngay; stripe = redirect Payment Links
VITE_PAYMENT_MODE=dev
VITE_STRIPE_LINK_STARTER=
VITE_STRIPE_LINK_PROFESSIONAL=
VITE_STRIPE_LINK_ENTERPRISE=
# Legacy aliases (optional)
VITE_STRIPE_LINK_BASIC=
VITE_STRIPE_LINK_PRO=

# Referee E2E local: xem docs/REFEREE-E2E.md
# Kiem tra: npm run test:supabase-referee

# AI Assistant Sprint 7 — mặc định tắt, không ảnh hưởng màn hình cũ
VITE_ENABLE_AI_ENGINE=false

# Sprint 10 — API / Marketplace / Integrations (default OFF)
VITE_API_ENABLED=false
VITE_MARKETPLACE_ENABLED=false
VITE_PAYMENT_DEFAULT_PROVIDER=mock

# Phase 11B — integration settings store (default: local; supabase when configured)
# VITE_INTEGRATIONS_STORE_MODE=memory|local|supabase
# VITE_INTEGRATIONS_SUPABASE=false

VITE_VNPAY_ENABLED=false
VITE_VNPAY_TMN_CODE=
VITE_VNPAY_HASH_SECRET=
VITE_VNPAY_RETURN_URL=
VITE_VNPAY_CALLBACK_URL=

VITE_MOMO_ENABLED=false
VITE_MOMO_PARTNER_CODE=
VITE_MOMO_ACCESS_KEY=
VITE_MOMO_SECRET_KEY=
VITE_MOMO_RETURN_URL=
VITE_MOMO_CALLBACK_URL=

VITE_STRIPE_ENABLED=false
VITE_STRIPE_SECRET_KEY=
VITE_STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_SUCCESS_URL=
VITE_STRIPE_CANCEL_URL=

VITE_ZALO_OA_ENABLED=false
VITE_ZALO_OA_APP_ID=
VITE_ZALO_OA_SECRET=
VITE_ZALO_OA_ACCESS_TOKEN=
VITE_ZALO_OA_REFRESH_TOKEN=

VITE_EMAIL_ENABLED=false
VITE_SMTP_HOST=
VITE_SMTP_PORT=
VITE_SMTP_USER=
VITE_SMTP_PASS=
VITE_SMTP_FROM=

VITE_SMS_ENABLED=false
VITE_SMS_PROVIDER=mock
VITE_SMS_API_KEY=
VITE_SMS_API_SECRET=

# force chi dung trong .env.test (Vitest).
VITE_SEED_DEMO=false

# Phase 19B — public signup (default OFF; owner bật sau review SQL + RPC)
VITE_AUTH_SIGNUP_ENABLED=false

# Phase 22 — Data consistency flags (xem docs/v5/DATA_CONSISTENCY_ENV_RUNBOOK.md)
# VITE_CLUB_CLOUD_SYNC=false
# VITE_COURT_ENGINE_STORE=local

# Phase 23C/23D — Team Tournament cloud sync + seed (staging — explicit true only)
# VITE_TEAM_TOURNAMENT_SUPABASE=true
# VITE_TEAM_TOURNAMENT_STORE_MODE=supabase
# SUPABASE_SERVICE_ROLE_KEY=...          # seed script only — never commit
# TEAM_TOURNAMENT_SEED_CLUB_ID=
# TEAM_TOURNAMENT_SEED_BLOB_PATH=tests/fixtures/team-tournament-blob-probe.json
# TEAM_TOURNAMENT_SEED_TENANT_ID=venue-staging-a

# Private Pairing Rules V2 + unified runtime (default OFF in examples)
# Local QA: set both true in .env.local (gitignored). Production: keep false until owner GO.
VITE_PRIVATE_PAIRING_RULES_ENABLED=false
VITE_UNIFIED_CONSTRAINT_ENGINE_ENABLED=false
# Optional admin Top-N simulation (never applies to live)
VITE_PRIVATE_PAIRING_SIMULATION_ENABLED=false
