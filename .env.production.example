# Copy thanh .env.production.local de build thu local, hoac dat tren Vercel (Environment Variables).

# Pickleball Scheduler Pro v4.0.0 — Production



VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

VITE_SEED_DEMO=false



# RBAC + Auth (production RC: bắt buộc true sau khi chạy SQL staging checklist)
VITE_RBAC_ENABLED=true



# Payment: dev = nang cap goi local; stripe = Payment Links

VITE_PAYMENT_MODE=dev

VITE_STRIPE_LINK_BASIC=

VITE_STRIPE_LINK_PRO=

