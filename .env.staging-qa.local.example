# Gitignored via *.local — staging QA (never commit)
#
# Dùng cho: npm run test:verify-tenant-isolation
#            node scripts/verify-cross-tenant-rls-staging.mjs

# Staging Supabase (project ref qyewbxjsiiyufanzcjcq)
STAGING_SUPABASE_URL=https://qyewbxjsiiyufanzcjcq.supabase.co
STAGING_SUPABASE_ANON_KEY=

# Owner A / Owner B JWT passwords (đăng ký qua /login staging)
STAGING_OWNER_A_PASSWORD=
STAGING_OWNER_B_PASSWORD=
STAGING_PLAYER_PASSWORD=

# Private Pairing Rules V2 — default false; set true only for TT-V6 staging QA
# (Vite app flags belong in Preview/.env.local for the scheduler app, not RPC staging scripts)
VITE_PRIVATE_PAIRING_RULES_ENABLED=false
VITE_UNIFIED_CONSTRAINT_ENGINE_ENABLED=false
VITE_PRIVATE_PAIRING_SIMULATION_ENABLED=false
